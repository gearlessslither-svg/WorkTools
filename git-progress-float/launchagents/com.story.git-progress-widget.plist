<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.story.git-progress-widget</string>

  <key>ProgramArguments</key>
  <array>
    <string>__HOME__/Library/Application Support/GitProgressFloat/git_progress_widget</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__HOME__/Library/Application Support/GitProgressFloat</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
  </dict>

  <key>StandardOutPath</key>
  <string>__HOME__/Library/Application Support/GitProgressFloat/results/widget.log</string>

  <key>StandardErrorPath</key>
  <string>__HOME__/Library/Application Support/GitProgressFloat/results/widget.log</string>
</dict>
</plist>
